# ============================================================
# CruiseRider - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)
# ============================================================

# ─── App ────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=generate-with-openssl-rand-hex-32
DEBUG=True

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Database ───────────────────────────────────────────────
# Local (SQLite - for development):
DATABASE_URL=sqlite+aiosqlite:///./cruiserider.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cruiserider

# ─── YouTube Data API v3 ────────────────────────────────────
# STEP 1: Go to console.cloud.google.com
# STEP 2: Create project → Enable "YouTube Data API v3"
# STEP 3: Create API Key under Credentials
YOUTUBE_API_KEY=AIzaSyDvd9mSIID-FIrw11uffijxYYUKztWJ2t0
YOUTUBE_CHANNEL_ID=UC2U8Jmwgb7erTe0tgXSWYyA

# ─── Instagram Graph API ─────────────────────────────────────
# STEP 1: developers.facebook.com → Create Business App
# STEP 2: Add Instagram Graph API product
# STEP 3: Connect Priyanshu's Instagram Business account
# STEP 4: Generate long-lived token (valid 60 days)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
FACEBOOK_PAGE_ID=

# ─── Anthropic / Claude AI ──────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Car Data APIs ──────────────────────────────────────────
# CarDekho: Contact partners@cardekho.com for API access
CARDEKHO_API_KEY=
# CarWale: Contact api@carwale.com
CARWALE_API_KEY=

# ─── Email Notifications ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
NOTIFICATION_EMAIL=priyanshu@gmail.com

# ─── Admin ──────────────────────────────────────────────────
ADMIN_KEY=set-a-strong-random-key-here
